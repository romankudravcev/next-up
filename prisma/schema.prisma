generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String?
  role      String   @default("user") // "admin" or "user"
  createdAt DateTime @default(now())
  invites   Invite[] @relation("InviteUser")
}

model Invite {
  token       String   @id
  email       String
  used        Boolean  @default(false)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  invitedBy   User?    @relation("InviteUser", fields: [invitedById], references: [id])
  invitedById String?
}

model Activity {
  id       String   @id
  name     String
  location String
  weather  String
  duration String
  type     String[]
  hidden   Boolean  @default(false)
}
